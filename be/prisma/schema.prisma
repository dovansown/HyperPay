generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String    @id @default(uuid()) @db.Uuid
  email                       String    @unique @db.VarChar(255)
  password                    String    @db.VarChar(255)
  fullName                    String?   @map("full_name") @db.VarChar(255)
  role                        UserRole  @default(USER)
  emailVerified               Boolean   @default(false) @map("email_verified")
  emailVerificationToken      String?   @map("email_verification_token") @db.VarChar(255)
  emailVerificationExpiresAt  DateTime? @map("email_verification_expires_at")
  totpSecret                  String?   @map("totp_secret") @db.VarChar(255)
  totpEnabledAt               DateTime? @map("totp_enabled_at")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")
  deletedAt                   DateTime? @map("deleted_at")

  bankAccounts       BankAccount[]
  userPlans          UserPlan[]
  userPackages       UserPackage[]
  webhooks           UserWebhook[]
  webhookDeliveryLogs WebhookDeliveryLog[]
  contents           Content[]
  editedRevisions    ContentRevision[] @relation("content_revision_editor")
  balance            UserBalance?
  loginHistories     UserLoginHistory[]
  verificationCodes  VerificationCode[]
  backupCodes        UserBackupCode[]

  @@map("users")
}

model UserLoginHistory {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  ip           String?  @db.VarChar(64)
  userAgentHash String  @map("user_agent_hash") @db.VarChar(64)
  userAgent    String?  @map("user_agent") @db.VarChar(512)
  city         String?  @db.VarChar(120)
  country      String?  @db.VarChar(120)
  firstSeenAt  DateTime @map("first_seen_at")
  lastSeenAt   DateTime @map("last_seen_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, userAgentHash])
  @@map("user_login_histories")
}

enum VerificationCodeType {
  EMAIL_VERIFY
  LOGIN_VERIFY
  CHANGE_PASSWORD
}

model VerificationCode {
  id        String               @id @default(uuid()) @db.Uuid
  userId    String               @map("user_id") @db.Uuid
  type      VerificationCodeType
  codeHash  String               @map("code_hash") @db.VarChar(255)
  expiresAt DateTime             @map("expires_at")
  usedAt    DateTime?            @map("used_at")
  metadata  Json?                @db.JsonB

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([userId, type, expiresAt])
  @@map("verification_codes")
}

model UserBackupCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  codeHash  String    @map("code_hash") @db.VarChar(255)
  usedAt    DateTime? @map("used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_backup_codes")
}

model SystemSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(120)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model UserBalance {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @map("user_id") @db.Uuid
  balanceVnd BigInt   @default(0) @map("balance_vnd")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_balances")
}

model Bank {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  code      String    @unique @db.VarChar(50)
  iconUrl   String?   @map("icon_url") @db.VarChar(512)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  planBanks PlanBank[]
  packageBanks PackageBank[]

  @@map("banks")
}

model BankAccount {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  bankName       String    @map("bank_name") @db.VarChar(255)
  accountNumber  String    @map("account_number") @db.VarChar(50)
  accountHolder  String?   @map("account_holder") @db.VarChar(255)
  apiToken       String    @map("api_token") @unique @db.VarChar(255)
  apiTokenSuffix String?   @map("api_token_suffix") @db.VarChar(8)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions BankTransaction[]
  webhookLinks UserWebhookAccount[]

  @@index([userId])
  @@map("bank_accounts")
}

model BankTransaction {
  id            String    @id @default(uuid()) @db.Uuid
  bankAccountId String    @map("bank_account_id") @db.Uuid
  externalId    String?   @map("external_id") @db.VarChar(100)
  amount        BigInt
  type          String    @db.VarChar(20)
  description   String?   @db.VarChar(512)
  paymentCode   String?   @map("payment_code") @db.VarChar(64)
  balance       BigInt?
  occurredAt    DateTime  @map("occurred_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([bankAccountId])
  @@map("bank_transactions")
}

model Plan {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @unique @db.VarChar(255)
  priceVnd        BigInt    @map("price_vnd")
  maxBankAccounts Int       @map("max_bank_accounts")
  maxTransactions Int       @map("max_transactions")
  durationDays    Int       @map("duration_days")
  description     String?   @db.VarChar(512)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  planBanks PlanBank[]
  userPlans UserPlan[]

  @@map("plans")
}

model Package {
  id                    String    @id @default(uuid()) @db.Uuid
  name                  String    @unique @db.VarChar(255)
  status                PackageStatus @default(ACTIVE)
  isDefault             Boolean   @default(false) @map("is_default")
  applyDefaultDiscount  Boolean   @default(false) @map("apply_default_discount")
  defaultStartAt        DateTime? @map("default_start_at")
  defaultEndAt          DateTime? @map("default_end_at")
  priceVnd              BigInt    @map("price_vnd")
  maxTransactions       Int       @map("max_transactions")
  maxWebhookDeliveries  Int       @map("max_webhook_deliveries")
  maxBankTypes          Int       @map("max_bank_types")
  durationDays          Int?      @map("duration_days")
  description           String?   @db.VarChar(512)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  userPackages         UserPackage[]
  packageBanks         PackageBank[]
  packageDurationPrices PackageDurationPrice[]

  @@map("packages")
}

model Duration {
  id             String    @id @default(uuid()) @db.Uuid
  name           String    @db.VarChar(120)
  months         Int
  days           Int
  sortOrder      Int       @default(0) @map("sort_order")
  isDefault      Boolean   @default(false) @map("is_default")
  discountPercent Int?     @map("discount_percent")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  packageDurationPrices PackageDurationPrice[]

  @@map("durations")
}

model PackageDurationPrice {
  id         String   @id @default(uuid()) @db.Uuid
  packageId  String   @map("package_id") @db.Uuid
  durationId String   @map("duration_id") @db.Uuid
  priceVnd   BigInt   @map("price_vnd")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  package  Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  duration Duration @relation(fields: [durationId], references: [id], onDelete: Restrict)

  @@unique([packageId, durationId])
  @@index([packageId])
  @@index([durationId])
  @@map("package_duration_prices")
}

enum PackageStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model PlanBank {
  id        String    @id @default(uuid()) @db.Uuid
  planId    String    @map("plan_id") @db.Uuid
  bankId    String    @map("bank_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)
  bank Bank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([bankId])
  @@unique([planId, bankId])
  @@map("plan_banks")
}

model UserPlan {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  planId           String    @map("plan_id") @db.Uuid
  startAt          DateTime  @map("start_at")
  endAt            DateTime  @map("end_at")
  usedBankAccounts Int       @default(0) @map("used_bank_accounts")
  usedTransactions Int       @default(0) @map("used_transactions")
  status           String    @default("active") @db.VarChar(20)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([planId])
  @@map("user_plans")
}

model UserPackage {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  packageId             String    @map("package_id") @db.Uuid
  startAt               DateTime  @map("start_at")
  endAt                 DateTime  @map("end_at")
  usedTransactions      Int       @default(0) @map("used_transactions")
  usedWebhookDeliveries Int       @default(0) @map("used_webhook_deliveries")
  usedBankTypes         Int       @default(0) @map("used_bank_types")
  status                String    @default("active") @db.VarChar(20)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  package Package @relation(fields: [packageId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([packageId])
  @@map("user_packages")
}

model PackageBank {
  id           String    @id @default(uuid()) @db.Uuid
  packageId    String    @map("package_id") @db.Uuid
  bankId       String    @map("bank_id") @db.Uuid
  accountLimit Int       @default(1) @map("account_limit")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  bank    Bank    @relation(fields: [bankId], references: [id], onDelete: Restrict)

  @@index([packageId])
  @@index([bankId])
  @@unique([packageId, bankId])
  @@map("package_banks")
}

model UserWebhook {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  url         String    @db.VarChar(512)
  secretToken String    @map("secret_token") @db.VarChar(255)
  contentType WebhookContentType @default(JSON) @map("content_type")
  authType    WebhookAuthType @default(NONE) @map("auth_type")
  authHeaderName String? @map("auth_header_name") @db.VarChar(100)
  authHeaderValue String? @map("auth_header_value") @db.VarChar(512)
  authBearerToken String? @map("auth_bearer_token") @db.VarChar(512)
  authUsername String? @map("auth_username") @db.VarChar(255)
  authPassword String? @map("auth_password") @db.VarChar(255)
  retryOnNon2xx Boolean @default(true) @map("retry_on_non_2xx")
  maxRetryAttempts Int @default(3) @map("max_retry_attempts")
  transactionDirection TransactionDirectionFilter @default(BOTH) @map("transaction_direction")
  requirePaymentCode Boolean @default(false) @map("require_payment_code")
  paymentCodeRuleEnabled Boolean @default(false) @map("payment_code_rule_enabled")
  paymentCodePrefix String? @map("payment_code_prefix") @db.VarChar(5)
  paymentCodeSuffixMinLength Int? @map("payment_code_suffix_min_length")
  paymentCodeSuffixMaxLength Int? @map("payment_code_suffix_max_length")
  paymentCodeSuffixCharset PaymentCodeCharset? @map("payment_code_suffix_charset")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedAccounts UserWebhookAccount[]

  @@index([userId])
  @@map("user_webhooks")
}

model UserWebhookAccount {
  id            String    @id @default(uuid()) @db.Uuid
  userWebhookId String    @map("user_webhook_id") @db.Uuid
  bankAccountId String    @map("bank_account_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  userWebhook UserWebhook @relation(fields: [userWebhookId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([userWebhookId])
  @@index([bankAccountId])
  @@unique([userWebhookId, bankAccountId])
  @@map("user_webhook_accounts")
}

model WebhookDeliveryLog {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  url                String    @db.VarChar(512)
  eventType          String    @map("event_type") @db.VarChar(64)
  responseStatusCode Int       @map("response_status_code")
  success            Boolean
  errorMessage       String?   @map("error_message") @db.VarChar(512)
  requestPayload     String?   @map("request_payload") @db.Text
  responseBody       String?   @map("response_body") @db.Text
  createdAt          DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("webhook_delivery_logs")
}

enum WebhookContentType {
  JSON
  FORM_URLENCODED
}

enum WebhookAuthType {
  NONE
  BEARER
  BASIC
  HEADER
}

enum TransactionDirectionFilter {
  IN
  OUT
  BOTH
}

enum PaymentCodeCharset {
  NUMERIC
  ALPHA
  ALPHANUMERIC
}

enum ContentType {
  BLOG_POST
  DOC_PAGE
  HELP_ARTICLE
}

enum ContentStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  USER
  AUTHOR
  EDITOR
  ADMIN
}

model Content {
  id          String    @id @default(uuid()) @db.Uuid
  type        ContentType
  status      ContentStatus @default(DRAFT)
  title       String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  excerpt     String?   @db.VarChar(512)
  content     String    @db.Text
  coverImage  String?   @map("cover_image") @db.VarChar(512)
  seoTitle    String?   @map("seo_title") @db.VarChar(255)
  seoDescription String? @map("seo_description") @db.VarChar(512)
  seoKeywords String?   @map("seo_keywords") @db.VarChar(512)
  scheduledPublishAt DateTime? @map("scheduled_publish_at")
  previewTokenHash String?  @map("preview_token_hash") @db.VarChar(255)
  previewTokenExpiredAt DateTime? @map("preview_token_expired_at")
  authorId    String?   @map("author_id") @db.Uuid
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  author     User?                     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  categories ContentCategoryOnContent[]
  tags       ContentTagOnContent[]
  revisions  ContentRevision[]

  @@index([type])
  @@index([status])
  @@index([publishedAt])
  @@index([scheduledPublishAt])
  @@map("contents")
}

model ContentRevision {
  id               String    @id @default(uuid()) @db.Uuid
  contentId        String    @map("content_id") @db.Uuid
  version          Int
  title            String    @db.VarChar(255)
  excerpt          String?   @db.VarChar(512)
  contentBody      String    @map("content_body") @db.Text
  coverImage       String?   @map("cover_image") @db.VarChar(512)
  status           ContentStatus
  seoTitle         String?   @map("seo_title") @db.VarChar(255)
  seoDescription   String?   @map("seo_description") @db.VarChar(512)
  seoKeywords      String?   @map("seo_keywords") @db.VarChar(512)
  categorySlugs    Json?     @map("category_slugs")
  tagSlugs         Json?     @map("tag_slugs")
  editedById      String?   @map("edited_by_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  editedBy User?  @relation("content_revision_editor", fields: [editedById], references: [id], onDelete: SetNull)

  @@unique([contentId, version])
  @@index([contentId])
  @@map("content_revisions")
}

model ContentCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(120)
  slug        String    @unique @db.VarChar(120)
  description String?   @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  contents ContentCategoryOnContent[]

  @@map("content_categories")
}

model ContentTag {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(120)
  slug        String    @unique @db.VarChar(120)
  description String?   @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  contents ContentTagOnContent[]

  @@map("content_tags")
}

model ContentCategoryOnContent {
  contentId  String   @map("content_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  content  Content         @relation(fields: [contentId], references: [id], onDelete: Cascade)
  category ContentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([contentId, categoryId])
  @@index([categoryId])
  @@map("content_category_on_content")
}

model ContentTagOnContent {
  contentId String   @map("content_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  content Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag     ContentTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentId, tagId])
  @@index([tagId])
  @@map("content_tag_on_content")
}
